# Frontend environment variables.
#
# PRODUCTION (set these in the Vercel dashboard, NOT in a committed file):
#   NEXT_PUBLIC_API_BASE = the public URL of your deployed backend (Railway)
NEXT_PUBLIC_API_BASE=https://your-backend.up.railway.app

# LOCAL DEV (optional): where next.config proxies /api to. Defaults to http://127.0.0.1:8000
# BACKEND_URL=http://127.0.0.1:8000
#
# For local overrides, copy this to `.env.local` (that file is gitignored, so no secrets leak).
